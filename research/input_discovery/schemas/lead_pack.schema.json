{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tensorleap.local/research/schemas/lead_pack.schema.json",
  "title": "PyTorch Lead Pack v1",
  "type": "object",
  "required": [
    "schema_version",
    "method_version",
    "generated_at",
    "experiment",
    "repo",
    "signals",
    "files",
    "totals"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "method_version": { "type": "string", "const": "pytorch-leads-v1" },
    "generated_at": { "type": "string", "format": "date-time" },
    "experiment": {
      "type": "object",
      "required": ["id", "repo_id", "repo_variant", "run_id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "repo_id": { "type": "string", "minLength": 1 },
        "repo_variant": { "type": "string", "minLength": 1 },
        "run_id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "repo": {
      "type": "object",
      "required": ["path", "python_files_scanned"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "python_files_scanned": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "weight", "tier"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "weight": { "type": "number", "minimum": 0 },
          "tier": { "type": "string", "enum": ["primary", "secondary"] }
        },
        "additionalProperties": false
      }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "score", "signal_hits"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "score": { "type": "number", "minimum": 0 },
          "signal_hits": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["signal_id", "count", "contribution", "occurrences"],
              "properties": {
                "signal_id": { "type": "string", "minLength": 1 },
                "count": { "type": "integer", "minimum": 1 },
                "contribution": { "type": "number", "minimum": 0 },
                "occurrences": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["line", "snippet"],
                    "properties": {
                      "line": { "type": "integer", "minimum": 1 },
                      "snippet": { "type": "string" }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "totals": {
      "type": "object",
      "required": ["files_with_hits", "signal_hit_count"],
      "properties": {
        "files_with_hits": { "type": "integer", "minimum": 0 },
        "signal_hit_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
